{
  // Cloudflare Worker + Container config for the Flask backend (api.group-ly.tech).
  // Deploy with: npx wrangler deploy
  "$schema": "node_modules/wrangler/config-schema.json",
  // Muss dem Namen des verbundenen Cloudflare-Workers-Projekts entsprechen,
  // sonst ueberschreibt das CI-System den Namen und meldet einen Mismatch.
  "name": "lerngruppen-finder",
  "main": "worker/index.js",
  "compatibility_date": "2025-05-01",

  // The container image is built from the repo Dockerfile at deploy time.
  "containers": [
    {
      "class_name": "Backend",
      "image": "./Dockerfile",
      "instance_type": "standard-1",
      // Sessions are cookie-based and all state is in Atlas, so more than one
      // instance is safe. Start conservative.
      "max_instances": 2
    }
  ],

  // A Durable Object is required to address/route the container. Its class_name
  // must match the exported class in worker/index.js and the container above.
  "durable_objects": {
    "bindings": [
      {
        "name": "BACKEND",
        "class_name": "Backend"
      }
    ]
  },

  // Container-backed Durable Objects must use new_sqlite_classes.
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Backend"]
    }
  ],

  // Non-secret defaults. Secrets (MONGODB_URI, FLASK_SECRET_KEY, OPENAI_API_KEY,
  // SMTP_*, ...) are set with `wrangler secret put` and injected into the
  // container's environment — NEVER commit them here.
  "vars": {
    "MONGODB_DB": "grouply",
    "SESSION_COOKIE_SECURE": "1",
    "SESSION_COOKIE_DOMAIN": ".group-ly.tech",
    "FLASK_ALLOWED_ORIGINS": "https://group-ly.tech,https://www.group-ly.tech"
  }
}
