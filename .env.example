# Kopieren nach .env im gleichen Ordner wie app.py und Werte eintragen.
# Die Datei .env wird von Git ignoriert.

# --- Flask (für echte Nutzung setzen) ---
# FLASK_SECRET_KEY=…   # z. B. python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=false
# Kommagetrennte Liste erlaubter Frontend-Origin-Domains (fuer CORS), z. B.:
FLASK_ALLOWED_ORIGINS=https://group-ly.tech,https://www.group-ly.tech

# --- Datenbank (MongoDB Atlas) ---
# Verbindungs-URI aus dem Atlas-Dashboard (Driver: Python). NICHT committen!
# MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
# Datenbankname (Default: grouply)
MONGODB_DB=grouply

# --- Session-Cookies (nur fuer Split-Origin-Produktion setzen) ---
# Frontend (group-ly.tech) und API (api.group-ly.tech) sind verschiedene
# Origins. Damit der Login-Cookie cross-site mitgeschickt wird:
#   SESSION_COOKIE_SECURE=1            -> aktiviert SameSite=None; Secure
#   SESSION_COOKIE_DOMAIN=.group-ly.tech
# Lokal (http://localhost) beide WEGLASSEN, sonst wird kein Cookie gesetzt.
# SESSION_COOKIE_SECURE=1
# SESSION_COOKIE_DOMAIN=.group-ly.tech

# --- Zeugnis-Auslesung (GPT Vision beim ersten Login) ---
# API-Key aus https://platform.openai.com (beginnt mit sk-...). NICHT committen!
# OPENAI_API_KEY=sk-...
# Optional: Modell fuer die Auslesung (Default: gpt-4o)
# ONBOARDING_MODEL=gpt-4o

# =============================================================================
# Gmail SMTP (Lehrer-E-Mails bei Laden-Käufen)
# =============================================================================
# 1) Google-Konto: 2-Faktor-Authentifizierung einschalten (Pflicht für App-Passwörter).
# 2) https://myaccount.google.com/apppasswords — App-Passwort erzeugen (16 Zeichen).
# 3) Unten deine Gmail-Adresse + das App-Passwort eintragen (NICHT dein normales Login-Passwort).
#
# Variante A — empfohlen (Port 587, STARTTLS, Standard in mailer.py):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine.adresse@gmail.com
SMTP_PASSWORD=dein-app-passwort
SMTP_FROM=deine.adresse@gmail.com
# SMTP_USE_SSL und SMTP_STARTTLS weglassen (Defaults: SSL aus, STARTTLS an)
#
# Variante B — alternativ Port 465 mit direktem SSL:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USE_SSL=1
# SMTP_STARTTLS=0
# SMTP_USER=deine.adresse@gmail.com
# SMTP_PASSWORD=hier-app-passwort
# SMTP_FROM=deine.adresse@gmail.com
#
# Google Workspace (eigene Domain): gleicher Host, USER/FROM = deine@schule.de
#
# SMTP_TIMEOUT=30
