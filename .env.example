# Kopieren nach .env im gleichen Ordner wie app.py und Werte eintragen.
# Die Datei .env wird von Git ignoriert.

# --- Flask (für echte Nutzung setzen) ---
# FLASK_SECRET_KEY=…   # z. B. python -c "import secrets; print(secrets.token_hex(32))"
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# FLASK_DEBUG=false

# --- SMTP (Lehrer-E-Mails bei Laden-Käufen, siehe mailer.py) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=deine.adresse@gmail.com
# SMTP_PASSWORD=app-passwort
# SMTP_FROM=deine.adresse@gmail.com
#
# Optional:
# SMTP_USE_SSL=1          # 1 = SMTP_SSL (typisch Port 465)
# SMTP_STARTTLS=0         # 0 = kein STARTTLS nach Verbindung (selten)
# SMTP_TIMEOUT=30         # Sekunden
