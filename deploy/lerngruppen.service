[Unit]
Description=Lerngruppen-Finder Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/path/to/lerngruppen-finder
Environment="PATH=/path/to/lerngruppen-finder/venv/bin"
EnvironmentFile=/path/to/lerngruppen-finder/.env
ExecStart=/path/to/lerngruppen-finder/venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 "app:app"
Restart=on-failure

[Install]
WantedBy=multi-user.target
